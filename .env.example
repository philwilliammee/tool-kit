# LiteLLM proxy
OPENAI_API_KEY=your_litellm_proxy_api_key
OPENAI_BASE_URL=https://your-litellm-proxy.example.com

# Bearer token for CLI → backend authentication
API_TOKEN=your_secret_bearer_token

# Backend port (optional, default: 3333)
PORT=3333

# Path to the mcp/ directory (optional, defaults to <project-root>/mcp)
MCP_ROOT=/absolute/path/to/tool-kit/mcp

# GitHub token — passed through to the octokit MCP server
GITHUB_TOKEN=your_github_personal_access_token
